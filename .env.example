POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=postgres
POSTGRES_PASSWORD=your_password
POSTGRES_DB=dvdrental

API_V1_PREFIX=/api/v1
PROJECT_NAME="DVDRental API"
DEBUG=false
ALLOWED_ORIGINS=["http://localhost:3000","http://localhost:5173"]

# ── Docker Compose 端口映射（宿主机侧）────────────────────────────────────
BACKEND_PORT=8000
FRONTEND_PORT=8080
DB_HOST_PORT=5433       # 内置 PostgreSQL 映射到宿主机端口（避免与本地 5432 冲突）
KEYCLOAK_PORT=8090      # Keycloak 映射到宿主机端口

# ── Keycloak OIDC IDP ────────────────────────────────────────────────────────
# ISSUER: token 中 iss claim 的值（浏览器视角的 URL）
# JWKS_URL: 后端拉取公钥的地址（Docker 内用 keycloak:8080，本地开发用 localhost:8090）
# CLIENT_ID: Keycloak public client 的 client_id
KEYCLOAK_ISSUER=http://localhost:8090/realms/dvd-rental
KEYCLOAK_JWKS_URL=http://localhost:8090/realms/dvd-rental/protocol/openid-connect/certs
KEYCLOAK_CLIENT_ID=dvd-rental-api

# Keycloak admin 账号（仅 docker-compose 内部 Keycloak 服务使用）
KEYCLOAK_ADMIN=admin
KEYCLOAK_ADMIN_PASSWORD=admin
